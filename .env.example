# 环境变量示例文件
# 复制此文件为 .env.local 并填入真实值
# 注意：.env.local 已被 .gitignore 忽略，不会提交到 GitHub

# Supabase 项目 URL（从 Supabase Dashboard → Settings → API 获取）
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase 公开 anon key（从 Supabase Dashboard → Settings → API 获取）
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key（可选，用于管理员功能，从 Supabase Dashboard → Settings → API 获取）
# 注意：此 key 有完全数据库权限，仅用于服务端操作，不要在前端暴露
VITE_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
